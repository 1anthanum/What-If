# Copy this to .env and fill in your values
WHATIF_ANTHROPIC_API_KEY=your-api-key-here
WHATIF_CLAUDE_MODEL=claude-sonnet-4-6
WHATIF_DEBUG=true

# ─── Local Model Configuration (Optional) ─────────────────────
# Uncomment and configure for local 7B model experiments.

# Ollama server URL (start Ollama first: `ollama serve`)
# WHATIF_OLLAMA_BASE_URL=http://localhost:11434

# Default single model for fast backend
# WHATIF_OLLAMA_MODEL=qwen2.5:7b

# Multi-model pool — each persona gets a different model (round-robin)
# Pull all models first: ollama pull qwen2.5:7b llama3.1:8b mistral:7b yi:6b gemma2:9b
# WHATIF_OLLAMA_MODEL_POOL=qwen2.5:7b,llama3.1:8b,mistral:7b,yi:6b,gemma2:9b

# Route ALL inference (including synthesis/analysis) through Ollama
# Not recommended for quality; useful for fully offline experiments.
# WHATIF_STRONG_BACKEND_OVERRIDE=ollama

# Auto-loop: max sequential autonomous exploration cycles
# WHATIF_AUTO_LOOP_MAX_CYCLES=10
# WHATIF_AUTO_LOOP_PAUSE_SECONDS=5.0
